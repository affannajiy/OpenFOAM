refinementRegions
{
    // Example for mode = inside
    <REGION_NAME>
    {
        mode        inside;
        levels      ((0 2));    // first value 0 is irrelevant, second value 2 indicates the refinement level
    }

    // Example for mode = outside
    <REGION_NAME>
    {
        mode        outside;
        levels      ((0 2));    // first value 0 is irrelevant, second value 2 indicates the refinement level
    }
    
    // Example for mode = distance
    <REGION_NAME>
    {
        mode        distance;

        levels
        (
            (0.5 6)    // Level 6 within 0.5 m of surface
            (2.0 4)    // Level 4 within 2.0 m of surface
            (5.0 2)    // Level 2 within 5.0 m of surface
        );
    }
}
