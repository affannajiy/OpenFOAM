refinementSurfaces
{
    // Type 1: Closer surface with multiple regions.
    // - By default, the different regions become individual patches of type wall
    // - faceZone, faceType, cellZoneInside, cellZone entries are useless inside
    // the regions subdict, e.g., inside Inflow subdict.
    outer-domain
    {
        level           (0 1);

        regions
        {
            Inflow
            {
                level           (1 2);
            }
            all_walls
            {
                level           (0 1);
            }
            Outflow
            {
                level           (1 2);
            }
        }
    }

    // Type 2: Surface with single region
    // Will become a single patch of type wall. If the surface is interior to a domain
    // then physically overlapping but mathematically separate faces will be 
    // formed on both sides of the surface. 
    transformer
    {
        level       (0 2);
    }

    // Type 3: Surface with single region and additional definitions
    // If faceType = internal, then the faces in the faceZone become internal faces
    // If faceType = baffle, two patches of type wall will be created: fz_transformer and fz_transformer_slave with connected points. So they move together in mesh motion
    // If faceType = boundary, then same behavior as baffle but the patches do not have shared points and are independent of each other.
    transformer
    {
        level       (0 2);
        faceZone    fz_transformer;     // user specified name of the faceZone
        faceType    internal;           // Default is internal. Can also be baffle or boundary
    }

    // Type 4: Surface with single region, faceZone definitions and enclosing a cellZone
    // Valid only for closed surfaces which has a volume. Not valid for open surfaces, e.g., fan patch
    transformer
    {
        level           (0 2);
        faceZone        fz_transformer;     // user specified name of the faceZone
        faceType        internal;           // When defining enclosing cellZone better to enforce this as internal only
        cellZoneInside  inside;             // inside or outside: inside = all cells inside the surface. outside = all cells outside the surface
        cellZone        cz_transformer;     // User defined cellZone name
    }
}
