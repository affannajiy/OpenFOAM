{
    "_info": {
        "description": "Built-in materials library for OpenFOAM electronics thermal management case setup",
        "version": "1.0",
        "notes": [
            "Each entry must be fully self-consistent — no cross-references between entries.",
            "Fluid entries require: molecular_weight, rho, Cp, mu, kappa (each with 'model' and value/coefficients).",
            "Solid entries require: molecular_weight, rho, Cp, kappa (scalars).",
            "Polynomial coefficients follow the 8-term form: P(T) = a0 + a1*T + a2*T^2 + ... + a7*T^7.",
            "_type and _description are metadata fields used by the resolver — do not remove them."
        ]
    },

    "air-temperature-dependent": {
        "_description": "Dry air — incompressible perfect gas (rho depends on T only via p_ref). Polynomial Cp, mu, kappa.",
        "_type": "fluid",
        "molecular_weight": 28.96,
        "rho": {
            "model": "ideal-gas-temperature-only"
        },
        "Cp": {
            "model": "polynomial",
            "coefficients": [1081.2, -0.54406, 0.0013155, -9.1045e-07, 2.07e-10, 0, 0, 0]
        },
        "mu": {
            "model": "polynomial",
            "coefficients": [2.8512e-06, 5.7901e-08, -1.8502e-11, 0, 0, 0, 0, 0]
        },
        "kappa": {
            "model": "polynomial",
            "coefficients": [0.0031657, 8.2626e-05, -1.9253e-08, 0, 0, 0, 0, 0]
        }
    },

    "air-ideal-gas": {
        "_description": "Dry air — full ideal gas (rho depends on p and T). Polynomial Cp, mu, kappa. For compressible solvers.",
        "_type": "fluid",
        "molecular_weight": 28.96,
        "rho": {
            "model": "ideal-gas"
        },
        "Cp": {
            "model": "polynomial",
            "coefficients": [1081.2, -0.54406, 0.0013155, -9.1045e-07, 2.07e-10, 0, 0, 0]
        },
        "mu": {
            "model": "polynomial",
            "coefficients": [2.8512e-06, 5.7901e-08, -1.8502e-11, 0, 0, 0, 0, 0]
        },
        "kappa": {
            "model": "polynomial",
            "coefficients": [0.0031657, 8.2626e-05, -1.9253e-08, 0, 0, 0, 0, 0]
        }
    },

    "air-constant": {
        "_description": "Dry air — constant properties evaluated at 25 degC, 1 atm.",
        "_type": "fluid",
        "molecular_weight": 28.96,
        "rho": {
            "model": "constant",
            "value": 1.184
        },
        "Cp": {
            "model": "constant",
            "value": 1005
        },
        "mu": {
            "model": "constant",
            "value": 1.846e-05
        },
        "kappa": {
            "model": "constant",
            "value": 0.026
        }
    },

    "water-liquid-constant": {
