{% macro render_fan_baffle(b) %}
    {{ b.patch_name }}
    {
        type        faceZone;
        zoneName    {{ b.faceZone_name }};

        patchPairs
        {
            type            cyclic;

            patchFields
            {
                p_rgh
                {
                    type            fan;
                    patchType       cyclic;
                    mode            volumeFlowRate;

                    jumpTable       csvFile;

                    jumpTableCoeffs
                    {
                        nHeaderLine         {{ b.skip_rows }};
                        refColumn           {{ b.ref_column }};
                        componentColumns    ({{ b.component_columns }});
                        separator           ",";
                        mergeSeparators     false;
                        file                "inputData/{{ b.csv_file }}";
                        outOfBounds         clamp;
                        interpolationScheme linear;
                    }
                    value           uniform {{ b.reference_pressure }};
                }
            }
        }
    }
{% endmacro %}
{# Add further macros here for future baffle types (e.g. render_porous_baffle, render_wall_baffle) #}
