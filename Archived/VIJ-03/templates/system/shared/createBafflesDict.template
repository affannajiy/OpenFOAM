FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "{{ location }}";
    object      createBafflesDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

internalFacesOnly true;

baffles
{
{% for baffle in baffles %}
{% if baffle.type == "fan" %}
{{ render_fan_baffle(baffle) }}
{% endif %}
{# Extend here: {% elif baffle.type == "porous" %}{{ render_porous_baffle(baffle) }}{% endif %} #}
{% endfor %}
}

