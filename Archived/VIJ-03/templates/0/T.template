{% macro render_inlet_T(name, thermal) %}
{% if thermal.is_time_varying %}
    {{ name }}
    {
        type                    uniformInletOutlet;
        uniformInletValue       csvFile;
        uniformInletValueCoeffs
        {
            nHeaderLine         {{ thermal.time_varying.skip_rows }};
            refColumn           {{ thermal.time_varying.ref_column }};
            componentColumns    ({{ thermal.time_varying.component_columns | join(' ') }});
            separator           ",";
            mergeSeparators     false;
            file                "inputData/{{ thermal.time_varying.csv_file }}";
            outOfBounds         clamp;
            interpolationScheme linear;
        }
        value                   $internalField;
    }

{% else %}
    {{ name }}
    {
        type        inletOutlet;
        inletValue  uniform {{ thermal.value }};
        value       $internalField;
    }

{% endif %}
{% endmacro %}
{% macro render_wall_T(name, thermal) %}
{% if thermal.mode == "temperature" %}
{% if thermal.is_time_varying %}
    {{ name }}
    {
        type                uniformFixedValue;
        uniformValue        csvFile;
        uniformValueCoeffs
        {
            nHeaderLine         {{ thermal.time_varying.skip_rows }};
            refColumn           {{ thermal.time_varying.ref_column }};
            componentColumns    ({{ thermal.time_varying.component_columns | join(' ') }});
            separator           ",";
            mergeSeparators     false;
            file                "inputData/{{ thermal.time_varying.csv_file }}";
            outOfBounds         clamp;
            interpolationScheme linear;
        }
    }

{% else %}
    {{ name }}
    {
        type    fixedValue;
        value   uniform {{ thermal.value }};
    }

{% endif %}
{% elif thermal.mode == "heat-flux" %}
    {{ name }}
    {
        type            externalWallHeatFluxTemperature;
        mode            flux;
        q               constant {{ thermal.q }};
        qr              {{ thermal.qr_value }};
        qrRelaxation    1;
        kappaMethod     {{ thermal.kappa_method }};
        {% if thermal.is_anisotropic %}
        alphaAni        aniAlpha;
        {% endif %}
        value           $internalField;
    }

{% elif thermal.mode == "heat-transfer-rate" %}
    {{ name }}
    {
        type            externalWallHeatFluxTemperature;
        mode            power;
        Q               constant {{ thermal.Q }};
        qr              {{ thermal.qr_value }};
        qrRelaxation    1;
        kappaMethod     {{ thermal.kappa_method }};
        {% if thermal.is_anisotropic %}
        alphaAni        aniAlpha;
        {% endif %}
        value           $internalField;
    }

{% elif thermal.mode == "heat-transfer-coefficient" %}
    {{ name }}
    {
        type            externalWallHeatFluxTemperature;
        mode            coefficient;
        Ta              constant {{ thermal.ambient_temperature }};
        h               constant {{ thermal.htc }};
        {% if thermal.has_emissivity %}
        emissivity      {{ thermal.emissivity }};
        {% endif %}
        qr              {{ thermal.qr_value }};
        qrRelaxation    1;
        {% if thermal.has_thermal_layers %}
        thicknessLayers ({{ thermal.thermal_layers | map(attribute='thickness') | join(' ') }});
        kappaLayers     ({{ thermal.thermal_layers | map(attribute='conductivity') | join(' ') }});
        {% endif %}
        kappaMethod     {{ thermal.kappa_method }};
        {% if thermal.is_anisotropic %}
        alphaAni        aniAlpha;
        {% endif %}
        value           $internalField;
    }

{% endif %}
{% endmacro %}
