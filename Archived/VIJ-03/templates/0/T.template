FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    location    "{{ location }}";
    object      T;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 0 0 1 0 0 0];

internalField   {{ internal_field }};

boundaryField
{
    {% if patches or cht_patches %}
    #includeEtc "caseDicts/setConstraintTypes"

    {# ── CHT interface patches ─────────────────────────────────────────────── #}
    {% for patch in cht_patches %}
    {{ patch.name }}
    {
        type            compressible::turbulentTemperatureRadCoupledMixed;
        Tnbr            T;
        qrNbr           {{ patch.qr_nbr }};
        qr              {{ patch.qr_value }};
        {% if patch.has_thermal_layers %}
        thicknessLayers ({{ patch.thermal_layers | map(attribute='thickness') | join(' ') }});
        kappaLayers     ({{ patch.thermal_layers | map(attribute='conductivity') | join(' ') }});
        {% endif %}
        kappaMethod     {{ patch.kappa_method }};
        {% if patch.is_anisotropic %}
        alphaAni        aniAlpha;
        {% endif %}
        value           $internalField;
    }

    {% endfor %}
    {% for patch in patches %}
    {# ── velocity-inlet / total-pressure-inlet ───────────────────────────── #}
    {% if patch.bc_type in ("velocity-inlet", "total-pressure-inlet") %}
    {% if patch.thermal %}{{ render_inlet_T(patch.name, patch.thermal) }}{% endif %}
    {# ── pressure-outlet ──────────────────────────────────────────────────── #}
    {% elif patch.bc_type == "pressure-outlet" %}
    {% if patch.prevent_backflow or not patch.backflow_thermal %}
    {{ patch.name }}
    {
        type    zeroGradient;
    }

    {% else %}{{ render_inlet_T(patch.name, patch.backflow_thermal) }}{% endif %}
    {# ── no-slip-wall / solid-wall ─────────────────────────────────────────── #}
    {% elif patch.bc_type in ("no-slip-wall", "solid-wall") %}
    {% if patch.thermal %}{{ render_wall_T(patch.name, patch.thermal) }}{% endif %}
    {# ── slip-wall ─────────────────────────────────────────────────────────── #}
    {% elif patch.bc_type == "slip-wall" %}
    {{ patch.name }}
    {
        type    slip;
    }

    {% endif %}
    {% endfor %}
    {% endif %}
}

