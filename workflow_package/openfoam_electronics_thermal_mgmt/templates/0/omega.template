{% macro render_omega_inlet(name, turb) %}
{% if turb.mode == "intensity-and-length-scale" %}
    {{ name }}
    {
        type            turbulentMixingLengthFrequencyInlet;
        mixingLength    {{ turb.length_scale }};
        value           $internalField;
    }

{% elif turb.mode == "dirichlet" %}
    {{ name }}
    {
        type        inletOutlet;
        inletValue  uniform {{ turb.omega }};
        value       $internalField;
    }

{% endif %}
{% endmacro %}
