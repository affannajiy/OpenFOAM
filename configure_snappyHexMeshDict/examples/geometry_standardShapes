geometry
{
    // Type 1: searchableBox
    // A cuboid given by two points on its diagonal.
    box
    {
        type            searchableBox;
        min             (1.5 1 -0.5);
        max             (3.5 2 0.5);
    }

    // Type 2: searchableCone
    // A cone (optionally it can be hollow)
    // For a solid cone, innerRadius1 and innerRadius2 will be 0
    cone
    {
        type            searchableCone;
        point1          (0 0 0);
        radius1         1.5;
        innerRadius1    0.25;
        point2          (10 0 0);
        radius2         3.0;
        innerRadius2    1.0;
    }

    // Type 3: searchableCylinder
    // A cylinder given by two points and a radius.
    cylinder
    {
        type            searchableCylinder;
        point1          (1.5 1 -0.5);
        point2          (3.5 2 0.5);
        radius          0.05;
    }

    // Type 4: searchableDisk
    // A disk with zero thickness based its origin, normal direction and radius.
    disk
    {
        type            searchableDisk;
        origin          (0 0 0);
        normal          (0 1 0);
        radius          0.314;
    }

    // Type 4: searchablePlane - Has 3 sub-types
    // 4.1 - Plane defined by point and a normal vector:
    plane
    {
        type            searchablePlane;
        planeType       pointAndNormal;

        pointAndNormalDict
        {
            basePoint       (1 1 1);
            normal          (0 1 0);
        }
    }

    // 4.2 - Plane defined by 3 points on the plane:
    plane
    {
        type            searchablePlane;
        planeType       embeddedPoints;

        embeddedPointsDict
        {
            point1          (1 1 1);
            point2          (0 1 0);
            point3          (0 0 1)
        }
    }

    // 4.3 - Plane defined by plane equation: a*x + b*y + c*z + d = 0
    plane
    {
        type            searchablePlane;
        planeType       planeEquation;

        planeEquationDict
        {
            a  0;
            b  0;
            c  1; // to create plane with normal towards +z direction ...
            d  2; // ... at coordinate: z = 2
        }
    }

    // Type 5 - searchablePlate
    // A finite plate aligned with co-ordinate system. User must specify span in two 
    // directions, the third must be zero. Plate could be used e.g. to create a baffle 
    // or measuring plane.
    plate
    {
        type            searchablePlate;
        origin          (0 0 0);
        span            (2 4 0);
    }

    // Type 6 - searchableRotatedBox
    // A cuboid defined via minimum and maximum co-ordinates, rotated about its 
    // centre according to a local co-ordinate system. The rotation is defined by 
    // a combination of vectors (e1/e2),(e2/e3) or (e3/e1)
    boxRotated
    {
        type            searchableRotatedBox;
        span            (5 4 3);
        origin          (0 0 0);
        e1              (1 0.5 0);
        e3              (0 0.5 1);
    }

    // Type 7 - searchableSphere
    // A sphere given by its centre radius.
    sphere
    {
        type            searchableSphere;
        centre          (0 0 0);
        radius          3;
    }

    // Type 8 - searchableSurfaceWithGaps
    // A searchableSurface that employs multiple slightly perturbed underlying 
    // surfaces to help prevent the mesh from leaking though small gaps.
    // Usage: The surface must be defined in the Geometry dictionary, 
    // to which a perturbation is applied to identify (and close) gaps.
    sphere.stl
    {
        type            triSurfaceMesh;
    }

    sphere
    {
        type            searchableSurfaceWithGaps;
        surface         sphere.stl;     // underlying surface
        gap             1e-3;           // perturbation distance
    }
}
